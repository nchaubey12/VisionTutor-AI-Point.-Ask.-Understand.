# ──────────────────────────────────────────────────────────────
#  gemini-vision-tutor — backend environment variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to git!
# ──────────────────────────────────────────────────────────────

# Required: Get a key from https://aistudio.google.com/
GEMINI_API_KEY=your-api-key-here

# Optional: Override the Gemini model used for analysis.
# The default (gemini-2.0-flash) is widely available on free and paid keys.
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-preview-04-17
# (preview models may require specific API key tiers)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Firebase / Firestore settings (if using cloud persistence)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
# FIREBASE_PROJECT_ID=your-project-id
