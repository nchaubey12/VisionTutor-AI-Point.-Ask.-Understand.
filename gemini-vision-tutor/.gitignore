__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
dist/
*.egg

# Node / Next.js
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Docker
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Google Cloud credentials
service-account-key.json
*-credentials.json
application_default_credentials.json
