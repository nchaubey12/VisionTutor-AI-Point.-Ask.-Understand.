# Gemini Vision Tutor - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Required ──────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud (optional - needed for Firestore/GCS) ───────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Optional ──────────────────────────────────────────────────────────────────
FIRESTORE_COLLECTION=tutor_sessions
GCS_BUCKET_NAME=your-project-gemini-vision-tutor-uploads
FRONTEND_URL=http://localhost:3000
PORT=8080
ENV=development

# ── Frontend (prefix with NEXT_PUBLIC_ to expose to browser) ─────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/tutor
